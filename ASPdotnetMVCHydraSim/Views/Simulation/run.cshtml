@using ASPdotnetMVCHydraSim.Domain.Components
<link href="~/css/Simulation.css" rel="stylesheet" />

<form method="post" action="/Simulation/Reset">
    <input type="hidden" name="id" value="0" />
    <button type="submit">Reset</button>
</form>

<div class="simulation">
    @foreach (var component in Model)
    {
        var style = $"grid-row:{component.CX};grid-column:{component.CY};";

        <div class="component @component.GetType().Name" id="@component.ComponentId" style="@style">
            @if (component is Pipe pipe)
            {
                var color = pipe.GetPipeColor((int)ViewBag.MaxPressure);
                <div style="background-color:@color;width:100%;height:100%;"></div>
            }
            else
            {
                <div class="label">@component.GetValue()</div>
            }
        </div>
    }
</div>

<script>
    document.querySelectorAll(".Resistance").forEach(comp => {
        comp.addEventListener("click", function () {
            const id = comp.id;
            const newValue = prompt(`Nieuwe weerstand voor component ${id}:`);
            if (newValue === null) return; // gebruiker klikte Cancel

            fetch(`/Simulation/UpdateResistancePressureDrop?simulationId=0&componentId=${id}&newPressureDrop=${newValue}`, {
                method: "POST",
            }).then(response => response.text())
              .then(html => {
                  document.open();
                  document.write(html);
                  document.close();
              });
        });
    });
</script>